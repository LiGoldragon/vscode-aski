{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Aski",
  "scopeName": "source.aski",
  "patterns": [
    { "include": "#comment" },
    { "include": "#string" },
    { "include": "#number" },
    { "include": "#builtin-function" },
    { "include": "#builtin-type" },
    { "include": "#self-ref" },
    { "include": "#generic-param" },
    { "include": "#mutable-ref" },
    { "include": "#borrow-ref" },
    { "include": "#instance-ref" },
    { "include": "#early-return" },
    { "include": "#piped-delimiters" },
    { "include": "#operator" },
    { "include": "#path-separator" },
    { "include": "#type-identifier" },
    { "include": "#identifier" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comment": {
      "match": ";;.*$",
      "name": "comment.line.semicolon.aski"
    },

    "string": {
      "name": "string.quoted.double.aski",
      "begin": "\"",
      "end": "\"",
      "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.aski" } },
      "endCaptures": { "0": { "name": "punctuation.definition.string.end.aski" } },
      "patterns": [
        {
          "match": "\\\\[nrt\\\\\"0]",
          "name": "constant.character.escape.aski"
        }
      ]
    },

    "number": {
      "patterns": [
        {
          "match": "\\b[0-9]+\\.[0-9]+\\b",
          "name": "constant.numeric.float.aski"
        },
        {
          "match": "\\b[0-9]+\\b",
          "name": "constant.numeric.integer.aski"
        }
      ]
    },

    "builtin-function": {
      "match": "\\b(StdOut|StdErr)\\b",
      "name": "support.function.builtin.aski"
    },

    "builtin-type": {
      "match": "\\b(U8|U16|U32|U64|U128|I8|I16|I32|I64|I128|F32|F64|Bool|String|Self|Vec|Map|Option|Result|Iterator|Pair|Triple)\\b",
      "name": "support.type.builtin.aski"
    },

    "self-ref": {
      "match": "@Self\\b",
      "name": "variable.language.self.aski"
    },

    "generic-param": {
      "match": "(\\$)([A-Z][a-zA-Z0-9]*)(&[A-Z][a-zA-Z0-9]*)*",
      "captures": {
        "1": { "name": "keyword.operator.sigil.aski" },
        "2": { "name": "entity.name.type.parameter.aski" }
      }
    },

    "mutable-ref": {
      "match": "(~)(@)(Self|[A-Z][a-zA-Z0-9]*)",
      "captures": {
        "1": { "name": "keyword.operator.mutable.aski" },
        "2": { "name": "keyword.operator.instance.aski" },
        "3": { "name": "variable.other.instance.aski" }
      }
    },

    "borrow-ref": {
      "match": "(:)(@)(Self|[A-Z][a-zA-Z0-9]*)",
      "captures": {
        "1": { "name": "keyword.operator.borrow.aski" },
        "2": { "name": "keyword.operator.instance.aski" },
        "3": { "name": "variable.other.instance.aski" }
      }
    },

    "instance-ref": {
      "match": "(@)([A-Z][a-zA-Z0-9]*)",
      "captures": {
        "1": { "name": "keyword.operator.instance.aski" },
        "2": { "name": "variable.other.instance.aski" }
      }
    },

    "early-return": {
      "match": "\\^",
      "name": "keyword.control.return.aski"
    },

    "piped-delimiters": {
      "patterns": [
        {
          "match": "\\(\\|",
          "name": "keyword.control.match.begin.aski"
        },
        {
          "match": "\\|\\)",
          "name": "keyword.control.match.end.aski"
        },
        {
          "match": "\\[\\|",
          "name": "keyword.control.process.begin.aski"
        },
        {
          "match": "\\|\\]",
          "name": "keyword.control.process.end.aski"
        },
        {
          "match": "\\{\\|",
          "name": "keyword.control.iteration.begin.aski"
        },
        {
          "match": "\\|\\}",
          "name": "keyword.control.iteration.end.aski"
        }
      ]
    },

    "operator": {
      "patterns": [
        {
          "match": "&&|\\|\\|",
          "name": "keyword.operator.logical.aski"
        },
        {
          "match": "==|!=|<=|>=",
          "name": "keyword.operator.comparison.aski"
        },
        {
          "match": "\\?",
          "name": "keyword.operator.propagation.aski"
        },
        {
          "match": "[+\\-*/%]",
          "name": "keyword.operator.arithmetic.aski"
        },
        {
          "match": "<|>",
          "name": "keyword.operator.comparison.aski"
        }
      ]
    },

    "path-separator": {
      "match": "/",
      "name": "punctuation.separator.path.aski"
    },

    "type-identifier": {
      "match": "\\b[A-Z][a-zA-Z0-9]*\\b",
      "name": "entity.name.type.aski"
    },

    "identifier": {
      "match": "\\b[a-z][a-zA-Z0-9]*\\b",
      "name": "entity.name.function.aski"
    },

    "punctuation": {
      "patterns": [
        {
          "match": "[\\(\\)\\[\\]\\{\\}]",
          "name": "punctuation.bracket.aski"
        },
        {
          "match": "\\.",
          "name": "punctuation.accessor.aski"
        },
        {
          "match": "\\|",
          "name": "punctuation.separator.aski"
        },
        {
          "match": "[~:@&$]",
          "name": "keyword.operator.sigil.aski"
        }
      ]
    }
  }
}
