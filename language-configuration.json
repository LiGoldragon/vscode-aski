{
  "comments": {
    "lineComment": ";;"
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["(|", "|)"],
    ["[|", "|]"],
    ["{|", "|}"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string"] },
    { "open": "(|", "close": "|)" },
    { "open": "[|", "close": "|]" },
    { "open": "{|", "close": "|}" }
  ],
  "surroundingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"" }
  ],
  "folding": {
    "markers": {
      "start": "^\\s*[\\[\\(\\{]",
      "end": "^\\s*[\\]\\)\\}]"
    }
  },
  "wordPattern": "(@?[A-Za-z][a-zA-Z0-9_]*)|([~:!^#])|([+\\-*/%<>=&|?.]+)"
}
