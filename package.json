{
  "name": "vscode-aski",
  "displayName": "Aski Language",
  "description": "Tree-sitter syntax highlighting for the Aski language",
  "version": "0.2.0",
  "publisher": "criome",
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:aski"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "aski",
        "aliases": ["Aski"],
        "extensions": [".aski"],
        "configuration": "./language-configuration.json"
      }
    ],
    "configurationDefaults": {
      "editor.semanticTokenColorCustomizations": {
        "rules": {
          "comment:aski":   "#505050",
          "keyword:aski":   "#bb44ee",
          "string:aski":    "#00cc44",
          "number:aski":    "#ff8800",
          "operator:aski":  "#ff5577",
          "type:aski":      "#f5c000",
          "function:aski":  "#e040a0",
          "variable:aski":  "#d0d0d0",
          "parameter:aski": "#ff0066",
          "macro:aski":     "#cc44ff",
          "regexp:aski":    "#b0b0b0"
        }
      }
    }
  },
  "dependencies": {
    "web-tree-sitter": "^0.26.8"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "esbuild": "^0.21.0",
    "typescript": "^5.0.0"
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --external:web-tree-sitter --format=cjs --platform=node",
    "package": "npx @vscode/vsce package"
  }
}
